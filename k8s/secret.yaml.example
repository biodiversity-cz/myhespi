# Tento soubor je VZOR. Nevkládejte do Git repozitáře skutečné hodnoty!
# Použití:
#   1. Zkopírujte jako secret.yaml
#   2. Nahraďte hodnoty svými (base64-kódovanými)
#   3. Aplikujte: kubectl apply -f secret.yaml -n <namespace>
#
# Kódování do base64:  echo -n "muj-token" | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: myhespi-secrets
type: Opaque
data:
  api-tokens: "NAHRADTE_BASE64_HODNOTOU"
  openai-api-key: "NAHRADTE_BASE64_HODNOTOU"
  hf-token: "NAHRADTE_BASE64_HODNOTOU"
